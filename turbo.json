{
    "$schema": "./node_modules/turbo/schema.json",
    "ui": "tui",
    "cacheDir": ".turbo/cache",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "start": {
            "dependsOn": [
                "build"
            ],
            "persistent": true,
            "cache": true
        },
        "check-types": {
            "dependsOn": [
                "^check-types"
            ]
        },
        "dev": {
            "persistent": true,
            "cache": true
        },
    }
}