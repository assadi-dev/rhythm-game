{
    "$schema": "./node_modules/turbo/schema.json",
    "ui": "tui",
    "cacheDir": ".turbo/cache",
    "globalDependencies": [
        ".env"
    ],
    "globalEnv": [
        "PORT",
        "NODE_ENV",
        "DATABASE_URL",
        "CORS_ORIGIN"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ]
        },
        "start": {
            "dependsOn": [
                "build"
            ],
            "persistent": true,
            "cache": false
        },
        "check-types": {
            "dependsOn": [
                "^check-types"
            ]
        },
        "dev": {
            "persistent": true,
            "cache": false
        },
    }
}